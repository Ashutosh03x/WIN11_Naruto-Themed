<ResourceDictionary  
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"  
    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <ResourceDictionary.MergedDictionaries>  
        <ResourceDictionary Source="pack://application:,,,/Themes/Win11Light.xaml" />  
    </ResourceDictionary.MergedDictionaries>  

    <!-- Core -->
    <system:Boolean x:Key="ThemeBlurEnabled">True</system:Boolean>  
    <system:String x:Key="SystemBG">Auto</system:String>  

    <!-- Naruto Base -->
    <Color x:Key="LightBG">#DD1A120A</Color>  
    <Color x:Key="DarkBG">#DD1A120A</Color>  

    <!-- Window -->
    <Style x:Key="WindowBorderStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource WindowBorderStyle}">
        <Setter Property="Background" Value="#DD1A120A"/>
        <Setter Property="BorderBrush" Value="#553A1F08"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="16"/>
    </Style>

    <!-- Query Box -->
    <Style x:Key="QueryBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource QueryBoxStyle}">
        <Setter Property="Foreground" Value="#FFEED5"/>
        <Setter Property="CaretBrush" Value="#FF8C2A"/>
        <Setter Property="SelectionBrush" Value="#55E8600A"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="QuerySuggestionBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource QuerySuggestionBoxStyle}">
        <Setter Property="Foreground" Value="#A08060"/>
    </Style>

    <!-- Items -->
    <Style x:Key="ItemTitleStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource ItemTitleStyle}">
        <Setter Property="Foreground" Value="#F5E6C8"/>
    </Style>

    <Style x:Key="ItemSubTitleStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource ItemSubTitleStyle}">
        <Setter Property="Foreground" Value="#A08060"/>
    </Style>

    <Style x:Key="ItemTitleSelectedStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource ItemTitleSelectedStyle}">
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <Style x:Key="ItemSubTitleSelectedStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource ItemSubTitleSelectedStyle}">
        <Setter Property="Foreground" Value="#FFD2A0"/>
    </Style>

    <!-- Selected Item Background (MAIN ORANGE ACCENT) -->
    <SolidColorBrush x:Key="ItemSelectedBackgroundColor">#33E8600A</SolidColorBrush>

    <!-- Bullet -->
    <Style x:Key="ItemBulletSelectedStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource ItemBulletSelectedStyle}">
        <Setter Property="Background" Value="#FF8C2A"/>
    </Style>

    <!-- Glyph -->
    <Style x:Key="ItemGlyph" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource ItemGlyph}">
        <Setter Property="Foreground" Value="#A08060"/>
    </Style>

    <Style x:Key="ItemGlyphSelectedStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource ItemGlyphSelectedStyle}">
        <Setter Property="Foreground" Value="#FFFFFF"/>
    </Style>

    <!-- Hotkeys -->
    <Style x:Key="ItemHotkeyStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="#7A5A3A"/>
    </Style>

    <Style x:Key="ItemHotkeySelectedStyle" TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="#FF8C2A"/>
    </Style>

    <!-- Separator -->
    <Style x:Key="SeparatorStyle" TargetType="{x:Type Rectangle}" BasedOn="{StaticResource SeparatorStyle}">
        <Setter Property="Fill" Value="#332E2618"/>
    </Style>

    <!-- Scrollbar -->
    <Style x:Key="ThumbStyle" TargetType="{x:Type Thumb}" BasedOn="{StaticResource ThumbStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Background="#553A1F08" CornerRadius="6"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Search Icon -->
    <Style x:Key="SearchIconStyle" TargetType="{x:Type Path}" BasedOn="{StaticResource SearchIconStyle}">
        <Setter Property="Fill" Value="#FF8C2A"/>
    </Style>

    <Style x:Key="SearchIconPosition" TargetType="{x:Type Canvas}" BasedOn="{StaticResource SearchIconPosition}">
    <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- Clock -->
    <Style x:Key="ClockBox" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource ClockBox}">
        <Setter Property="Foreground" Value="#A08060"/>
    </Style>

    <Style x:Key="DateBox" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource DateBox}">
        <Setter Property="Foreground" Value="#A08060"/>
    </Style>

    <!-- Preview -->
    <Style x:Key="PreviewBorderStyle" TargetType="{x:Type Border}" BasedOn="{StaticResource PreviewBorderStyle}">
        <Setter Property="BorderBrush" Value="#3A1F08"/>
    </Style>

    <Style x:Key="PreviewItemTitleStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource PreviewItemTitleStyle}">
        <Setter Property="Foreground" Value="#4AB8FF"/>
    </Style>

    <Style x:Key="PreviewItemSubTitleStyle" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource PreviewItemSubTitleStyle}">
        <Setter Property="Foreground" Value="#6B4E2E"/>
    </Style>

    <Style x:Key="PreviewGlyph" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource PreviewGlyph}">
        <Setter Property="Foreground" Value="#4AB8FF"/>
    </Style>

    </ResourceDictionary>
